# Sample flow — orchestrates requests from sample.http
# Demonstrates: sequential dependencies, variable capture, parallel steps
# Run with: hello_client run-flow sample.flow

flow {
  name: Sample User Flow
  description: GET, POST with capture, parallel PUT + headers, then DELETE
}

env {
  base_url: https://httpbin.org
  token: my-secret-token
  user_id: 42
}

step get_anything {
  file: sample.http
  entry: users/get anything
}

step post_user {
  file: sample.http
  entry: users/post json body
  depends_on: get_anything
  capture {
    echoed_name: res.body.json.name
  }
}

parallel finish {
  depends_on: post_user

  step put_update {
    file: sample.http
    entry: users/put update
  }
  step echo_headers {
    file: sample.http
    entry: headers/echo
  }
}

step delete_user {
  file: sample.http
  entry: users/delete
  depends_on: finish
}
