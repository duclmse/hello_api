{
  "opencollection": "1.0.0",
  "info": {
    "name": "Sample Collection",
    "version": "1.0.0"
  },
  "config": {
    "environments": [
      {
        "name": "default",
        "selected": true,
        "variables": [
          { "name": "base_url", "value": "https://httpbin.org" },
          { "name": "token", "value": "my-secret-token" },
          { "name": "user_id", "value": "42" }
        ]
      }
    ]
  },
  "items": [
    {
      "info": { "name": "users", "sequence": 1 },
      "items": [
        {
          "info": { "name": "get anything", "sequence": 1 },
          "http": {
            "method": "GET",
            "url": "{{base_url}}/anything",
            "headers": [
              { "name": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "info": { "name": "get with bearer auth", "sequence": 2 },
          "http": {
            "method": "GET",
            "url": "{{base_url}}/bearer"
          },
          "auth": {
            "type": "bearer",
            "bearer": { "token": "{{token}}" }
          },
          "runtime": {
            "assertions": [
              { "expression": "status", "operator": "equals", "value": 200 }
            ]
          }
        },
        {
          "info": { "name": "post json body", "sequence": 3 },
          "http": {
            "method": "POST",
            "url": "{{base_url}}/post",
            "headers": [
              { "name": "Accept", "value": "application/json" }
            ],
            "body": {
              "type": "raw",
              "contentType": "application/json",
              "body": "{\"id\": \"{{user_id}}\", \"name\": \"Alice\", \"email\": \"alice@example.com\"}"
            }
          },
          "runtime": {
            "scripts": [
              {
                "type": "tests",
                "code": "pm.test(\"echoes request body\", function () {\n  var body = pm.response.json();\n  pm.expect(body.json.name).to.equal(\"Alice\");\n});"
              }
            ],
            "assertions": [
              { "expression": "status", "operator": "equals", "value": 200 }
            ]
          }
        },
        {
          "info": { "name": "put update", "sequence": 4 },
          "http": {
            "method": "PUT",
            "url": "{{base_url}}/put",
            "body": {
              "type": "raw",
              "contentType": "application/json",
              "body": "{\"id\": \"{{user_id}}\", \"name\": \"Alice Updated\"}"
            }
          },
          "auth": {
            "type": "bearer",
            "bearer": { "token": "{{token}}" }
          }
        },
        {
          "info": { "name": "delete", "sequence": 5 },
          "http": {
            "method": "DELETE",
            "url": "{{base_url}}/delete"
          },
          "auth": {
            "type": "bearer",
            "bearer": { "token": "{{token}}" }
          }
        },
        {
          "info": { "name": "post form urlencoded", "sequence": 6 },
          "http": {
            "method": "POST",
            "url": "{{base_url}}/post",
            "body": {
              "type": "formUrlEncoded",
              "form": [
                { "name": "username", "value": "alice" },
                { "name": "role", "value": "admin" }
              ]
            }
          }
        }
      ]
    },
    {
      "info": { "name": "headers/echo", "sequence": 2 },
      "http": {
        "method": "GET",
        "url": "{{base_url}}/headers",
        "headers": [
          { "name": "X-Custom-Header", "value": "hello" },
          { "name": "X-Request-Id", "value": "req-001" }
        ]
      },
      "runtime": {
        "assertions": [
          { "expression": "status", "operator": "equals", "value": 200 },
          { "expression": "body", "operator": "isDefined" }
        ]
      }
    }
  ]
}
